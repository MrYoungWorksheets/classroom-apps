rules_version = '2';

// Starter rules for Sector Drift cloud-save backup testing.
// Review and harden these rules before any future multiplayer, PvP, shared economy,
// shared planets, teacher dashboard, or classroom-wide admin features go live.
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isTeacher() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "teacher";
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isTeacher();

      // Students can create only their own profile and only with the default role.
      allow create: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == "student";

      // Students can update safe profile fields but cannot change uid or role.
      allow update: if isSelf(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.uid == resource.data.uid;

      // Teachers may adjust student fields later if needed. Keep teacher tooling role-gated.
      allow update: if isTeacher();

      allow delete: if false;
    }

    match /players/{uid} {
      // Cloud backups are private to each signed-in user. Teachers can read/write for support.
      allow read: if isSelf(uid) || isTeacher();
      allow create: if isSelf(uid) || isTeacher();
      allow update: if isSelf(uid) || isTeacher();
      allow delete: if false;
    }

    function publicProfileFieldsOnly() {
      return request.resource.data.keys().hasOnly([
        'uid', 'captainName', 'title', 'specialty', 'shipName', 'currentSector',
        'status', 'lastSeenAt', 'totalScore', 'sectorsExplored', 'piratesDefeated',
        'missionsCompleted', 'tradeProfit', 'creditsEarned', 'reputation', 'achievementsCount'
      ]);
    }

    function publicEventFieldsOnly() {
      return request.resource.data.keys().hasOnly([
        'uid', 'captainName', 'eventType', 'message', 'sectorNumber', 'createdAt', 'public'
      ]);
    }

    match /sectorDriftPublicProfiles/{uid} {
      // Public profile is display/leaderboard data only; it must not contain email,
      // full save data, exact cargo inventory, dev codes, private save data, or cloud backups.
      // Client-reported stats are acceptable for early classroom competition, but not cheat-proof.
      allow read: if signedIn();
      allow create, update: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && publicProfileFieldsOnly();
      allow delete: if false;
    }

    match /sectorDriftPublicEvents/{eventId} {
      // System-generated public activity only. No chat, PvP, cargo trades, stealing,
      // or server-authoritative combat is implemented here. Future direct PvP/trading
      // must require server-authoritative validation or stricter rules.
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.public == true
        && publicEventFieldsOnly();
      allow update, delete: if false;
    }

    match /sectorDriftPresence/{uid} {
      // Display-only classroom presence. Never treat this as authority for credits,
      // cargo, combat, ownership, PvP, trading, stealing, or shared economy.
      allow read: if signedIn();
      allow create, update: if isSelf(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid', 'displayName', 'captainName', 'sectorNumber', 'shipName',
          'status', 'specialty', 'updatedAt', 'lastSeenAt', 'prototypeVersion'
        ]);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
